{
  "name": "qwen3_8b_openrouter_arch2_controller",
  "architecture_name": "arch2",
  "provider": {
    "api_base": "https://openrouter.ai/api/v1",
    "api_key_env": "OPENROUTER_API_KEY",
    "timeout_sec": 180
  },
  "defaults": {
    "model": "qwen/qwen3-8b",
    "temperature": 0.0,
    "max_tokens": 1200
  },
  "architecture": {
    "family": "architecture_2",
    "description": "Arch2: frozen specialist committee + reasoning-aware learned controller (GRPO + RLVR)",
    "specialization_source": "frozen_specialists_prompt_scaffold",
    "stage_sequence": [
      "coordinator_plan",
      "researcher",
      "analyst",
      "critic",
      "coordinator_finalize"
    ],
    "paper_reference_role_order": [
      "coordinator",
      "researcher",
      "analyst",
      "critic",
      "coordinator"
    ]
  },
  "controller": {
    "hidden_size": 128,
    "state_dim": 28,
    "n_phases": 6,
    "n_actions": 6,
    "semantic_embedding_dim": 384,
    "semantic_projection_dim": 32,
    "semantic_delta_dim": 384,
    "semantic_delta_projection_dim": 16,
    "task_progress_dim": 2
  },
  "training": {
    "grpo_group_size": 4,
    "phase_loss_weight": 0.1,
    "entropy_coef": 0.01,
    "lr": 0.0003,
    "grad_clip": 1.0
  },
  "reward": {
    "type": "verifiable",
    "hotpotqa_f1_threshold": 0.6,
    "gpqa_match": "letter_exact"
  },
  "models": {
    "committee": "qwen/qwen3-8b",
    "phase_classifier": "anthropic/claude-haiku-4-5-20251001",
    "semantic_encoder": "all-MiniLM-L6-v2"
  },
  "roles": {
    "coordinator_plan": {
      "system_prompt_path": "../prompts/coordinator_plan.md",
      "role_specialization": "coordinator",
      "checkpoint_name": "openrouter-qwen3-8b-frozen-specialist",
      "temperature": 0.0,
      "max_tokens": 1000
    },
    "researcher": {
      "system_prompt_path": "../prompts/researcher.md",
      "role_specialization": "researcher",
      "checkpoint_name": "openrouter-qwen3-8b-frozen-specialist",
      "temperature": 0.0,
      "max_tokens": 1200
    },
    "analyst": {
      "system_prompt_path": "../prompts/analyst.md",
      "role_specialization": "analyst",
      "checkpoint_name": "openrouter-qwen3-8b-frozen-specialist",
      "temperature": 0.0,
      "max_tokens": 1000
    },
    "critic": {
      "system_prompt_path": "../prompts/critic.md",
      "role_specialization": "critic",
      "checkpoint_name": "openrouter-qwen3-8b-frozen-specialist",
      "temperature": 0.0,
      "max_tokens": 800
    },
    "coordinator_finalize": {
      "system_prompt_path": "../prompts/coordinator_finalize.md",
      "role_specialization": "coordinator",
      "checkpoint_name": "openrouter-qwen3-8b-frozen-specialist",
      "temperature": 0.0,
      "max_tokens": 1000
    }
  }
}
