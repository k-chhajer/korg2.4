{
  "name": "qwen3_8b_ollama_eval",
  "provider": {
    "api_base": "http://127.0.0.1:11434/v1",
    "api_key_env": "OPENAI_API_KEY",
    "timeout_sec": 600
  },
  "defaults": {
    "model": "qwen3:8b",
    "temperature": 0.0,
    "max_tokens": 1400
  },
  "architecture": {
    "family": "architecture_2",
    "description": "Architecture 2 local evaluation scaffold on Ollama qwen3:8b with fixed coordinator -> researcher -> analyst -> critic -> coordinator flow.",
    "specialization_source": "prompt_scaffold_only",
    "stage_sequence": [
      "coordinator_plan",
      "researcher",
      "analyst",
      "critic",
      "coordinator_finalize"
    ],
    "paper_reference_role_order": [
      "coordinator",
      "researcher",
      "analyst",
      "critic",
      "coordinator"
    ]
  },
  "roles": {
    "coordinator_plan": {
      "system_prompt_path": "../prompts/coordinator_plan.md",
      "role_specialization": "coordinator",
      "checkpoint_name": "qwen3-8b-ollama-dev-scaffold",
      "temperature": 0.0,
      "max_tokens": 1200
    },
    "researcher": {
      "system_prompt_path": "../prompts/researcher.md",
      "role_specialization": "researcher",
      "checkpoint_name": "qwen3-8b-ollama-dev-scaffold",
      "temperature": 0.0,
      "max_tokens": 1600
    },
    "analyst": {
      "system_prompt_path": "../prompts/analyst.md",
      "role_specialization": "analyst",
      "checkpoint_name": "qwen3-8b-ollama-dev-scaffold",
      "temperature": 0.0,
      "max_tokens": 1400
    },
    "critic": {
      "system_prompt_path": "../prompts/critic.md",
      "role_specialization": "critic",
      "checkpoint_name": "qwen3-8b-ollama-dev-scaffold",
      "temperature": 0.0,
      "max_tokens": 1200
    },
    "coordinator_finalize": {
      "system_prompt_path": "../prompts/coordinator_finalize.md",
      "role_specialization": "coordinator",
      "checkpoint_name": "qwen3-8b-ollama-dev-scaffold",
      "temperature": 0.0,
      "max_tokens": 1400
    }
  }
}
