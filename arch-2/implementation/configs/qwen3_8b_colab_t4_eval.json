{
  "name": "qwen3_8b_colab_t4_eval",
  "provider": {
    "api_base": "http://127.0.0.1:8000/v1",
    "api_key_env": "OPENAI_API_KEY",
    "timeout_sec": 1800
  },
  "defaults": {
    "model": "Qwen/Qwen3-8B-AWQ",
    "temperature": 0.0,
    "max_tokens": 1400
  },
  "architecture": {
    "family": "architecture_1",
    "description": "Architecture 1 evaluation scaffold for a Colab-hosted Qwen3-8B-AWQ OpenAI-compatible endpoint on a T4 runtime.",
    "specialization_source": "prompt_scaffold_only",
    "stage_sequence": [
      "coordinator_plan",
      "researcher",
      "analyst",
      "critic",
      "coordinator_finalize"
    ],
    "paper_reference_role_order": [
      "coordinator",
      "researcher",
      "analyst",
      "critic",
      "coordinator"
    ]
  },
  "roles": {
    "coordinator_plan": {
      "system_prompt_path": "../prompts/coordinator_plan.md",
      "role_specialization": "coordinator",
      "checkpoint_name": "colab-t4-qwen3-8b-awq-scaffold",
      "temperature": 0.0,
      "max_tokens": 1200,
      "extra_body": {
        "chat_template_kwargs": {
          "enable_thinking": true
        }
      }
    },
    "researcher": {
      "system_prompt_path": "../prompts/researcher.md",
      "role_specialization": "researcher",
      "checkpoint_name": "colab-t4-qwen3-8b-awq-scaffold",
      "temperature": 0.0,
      "max_tokens": 1600
    },
    "analyst": {
      "system_prompt_path": "../prompts/analyst.md",
      "role_specialization": "analyst",
      "checkpoint_name": "colab-t4-qwen3-8b-awq-scaffold",
      "temperature": 0.0,
      "max_tokens": 1400
    },
    "critic": {
      "system_prompt_path": "../prompts/critic.md",
      "role_specialization": "critic",
      "checkpoint_name": "colab-t4-qwen3-8b-awq-scaffold",
      "temperature": 0.0,
      "max_tokens": 1200
    },
    "coordinator_finalize": {
      "system_prompt_path": "../prompts/coordinator_finalize.md",
      "role_specialization": "coordinator",
      "checkpoint_name": "colab-t4-qwen3-8b-awq-scaffold",
      "temperature": 0.0,
      "max_tokens": 1400,
      "extra_body": {
        "chat_template_kwargs": {
          "enable_thinking": true
        }
      }
    }
  }
}
